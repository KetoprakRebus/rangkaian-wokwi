#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);  // Alamat I2C LCD (0x27)

const int pirPin = 3;  
int motionDetected = 0;  
int distance = 0;  

void setup() {
  pinMode(pirPin, INPUT);
  Serial.begin(9600);

  lcd.init();
  lcd.backlight();

  Wire.begin();  // Inisialisasi sebagai master
}

void loop() {
  motionDetected = digitalRead(pirPin);
  
  Wire.requestFrom(8, 1);  // ini minta 1 byte data dari slave dengan alamat 8
  
  if (Wire.available()) {
    distance = Wire.read(); 
  }

  lcd.setCursor(0, 0);
  lcd.print("PIR: ");
  if (motionDetected == HIGH) {
    lcd.print("Motion detected");
  } else {
    lcd.print("No motion");
  }
  
  lcd.setCursor(0, 1);
  lcd.print("Distance: ");
  lcd.print(distance); 
  lcd.print(" cm");

  delay(1000); 
}
